[project]
name = "aam-backup-automation"
version = "1.0.0"
description = "AAM Backup Automation — nightly backup via Robocopy (LAN) and Rclone (GCS), orchestrated by Prefect 3"
readme = "DEPLOYMENT_GUIDE.md"
requires-python = ">=3.12"
authors = [{ name = "AAM Associates" }]
classifiers = ["Operating System :: Microsoft Windows"]

dependencies = [
    "prefect>=3.4.0",
    "pydantic>=2.0",
    "loguru>=0.7.3",
    "pyyaml>=6.0",
    "wakeonlan>=3.1.0",
    "fastapi>=0.115.0",
    "uvicorn>=0.30.0",
    "httpx>=0.27.0",
    "pendulum>=3.0.0",
    "psutil>=6.0.0",
    "prefect-mcp>=0.0.1b10",
    "ruamel.yaml>=0.18.0",
    "humanize>=4.0",
    "exceptiongroup>=1.0",
]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.ruff.format]
quote-style = "double"

[tool.ruff.lint]
select = ["E", "F", "I", "N", "UP", "B", "SIM"]
ignore = ["E501"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "-v --tb=short"
filterwarnings = ["ignore::DeprecationWarning"]
pythonpath = ["."]
